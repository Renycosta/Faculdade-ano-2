generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Candidata {
  id           Int             @id @default(autoincrement())
  nome         String          @db.VarChar(60) 
  clube        String          @db.VarChar(20) 
  idade        Int             @db.SmallInt
  escolaridade Escolaridade
  sonho        String          @db.VarChar(80) 
  n_votos      Int             @default(0)
  votos        Voto[]
  @@map("candidatas")
}

model Cliente {
  id           Int             @id @default(autoincrement())
  nome         String          @db.VarChar(60) 
  cpf          String          @db.VarChar(14)
  email        String          @db.VarChar(80)@unique
  cidade       String          @db.VarChar(40)
  votos        Voto[]
  @@map("clientes")
}

model Voto {
  id           Int             @id @default(autoincrement())
  candidata    Candidata       @relation(fields: [candidataId], references: [id])
  candidataId  Int
  cliente      Cliente         @relation(fields: [clienteId], references: [id])
  clienteId    Int
  data         DateTime        @default("2026-04-17T00:00:00.000Z")
  justi        String?         @db.VarChar(120) 
  @@map("votos")
}

enum Escolaridade {
  Ensino_Médio
  Graduação
  Pós_Graduação
}