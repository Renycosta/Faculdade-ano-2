generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Viagem {
  id           Int           @id @default(autoincrement())
  destino      String        @db.VarChar(60) 
  transporte   Transportes   @default(Terrestre)
  preco        Decimal       @db.Decimal(10, 2)
  dataSaida    DateTime
  dataRetorno  DateTime
  roteiro      String?       @db.Text
  @@map("viagens")
}

enum Transportes {
  Terrestre
  Maritimo
  Aereo
}
